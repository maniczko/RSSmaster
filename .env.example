# Shared runtime
RSSMASTER_ENV=development
RSSMASTER_APP_NAME=rssmaster
RSSMASTER_TIMEZONE=Europe/Warsaw

# Ports and URLs
RSSMASTER_WEB_PORT=3000
RSSMASTER_API_HOST=127.0.0.1
RSSMASTER_API_PORT=8000
RSSMASTER_WEB_URL=http://127.0.0.1:3000
RSSMASTER_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Local storage
RSSMASTER_DATABASE_PATH=./data/rssmaster.db

# Runtime limits
RSSMASTER_DIGEST_MAX_ITEMS=25
RSSMASTER_FETCH_TIMEOUT_SECONDS=20

# Optional Sentry monitoring
RSSMASTER_SENTRY_DSN=
RSSMASTER_SENTRY_TRACES_SAMPLE_RATE=0.1
RSSMASTER_SENTRY_ENABLE_LOGS=false
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional delivery settings
RSSMASTER_SMTP_HOST=
RSSMASTER_SMTP_PORT=587
RSSMASTER_SMTP_USERNAME=
RSSMASTER_SMTP_PASSWORD=
RSSMASTER_SMTP_FROM=
RSSMASTER_KINDLE_EMAIL=
